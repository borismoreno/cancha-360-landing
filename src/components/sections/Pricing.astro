---
import SectionLabel from '../ui/SectionLabel.astro'
import PricingCard from '../ui/PricingCard.astro'
---

<section class="bg-white py-20 md:py-28" id="precios">
  <div class="max-w-6xl mx-auto px-6 md:px-12">
    
    <div class="text-center max-w-xl mx-auto mb-14">
      <SectionLabel text="PRECIOS TRANSPARENTES" dark={true} />
      <h2 class="mt-5 text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 leading-tight" style="font-family: 'Lexend', sans-serif;">
        Elige el plan para tu academia
      </h2>
      <p class="mt-4 text-base text-gray-500">Empieza gratis, crece cuando estés listo.</p>
    </div>

    <!-- Billing toggle -->
    <div class="flex items-center justify-center gap-3 mb-10">
      <span class="text-sm text-gray-500 font-medium">Mensual</span>
      <label class="relative inline-flex items-center cursor-pointer">
        <input type="checkbox" id="billing-toggle" class="sr-only peer" checked>
        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:bg-linear-to-r peer-checked:from-primary peer-checked:to-secondary after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-5"></div>
      </label>
      <span class="text-sm font-semibold text-gray-900">Anual <SectionLabel text="2 meses gratis" dark={true}/></span>
      <!-- <span class="text-sm font-semibold text-gray-900">Anual <span class="gradient-text">— 2 meses gratis</span></span> -->
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto items-start">
      
      <!-- FREE -->
      <div class="card-light">
        <div class="inline-block bg-gray-100 text-gray-600 text-xs font-bold uppercase tracking-wide rounded-full px-3 py-1 mb-5">Para empezar</div>
        <div class="mb-6">
          <span class="text-4xl font-extrabold text-gray-900" style="font-family: 'Lexend';">$0</span>
          <span class="text-gray-500 text-sm ml-1">/mes</span>
          <p class="text-xs text-gray-400 mt-1">Para siempre</p>
        </div>
        <ul class="space-y-3 mb-8">
          <li class="flex items-center gap-2.5 text-sm text-gray-600"><span class="text-primary font-bold">✓</span> 1 equipo</li>
          <li class="flex items-center gap-2.5 text-sm text-gray-600"><span class="text-primary font-bold">✓</span> Hasta 15 jugadores</li>
          <li class="flex items-center gap-2.5 text-sm text-gray-600"><span class="text-primary font-bold">✓</span> 1 entrenador</li>
          <li class="flex items-center gap-2.5 text-sm text-gray-600"><span class="text-primary font-bold">✓</span> Registro de asistencia</li>
          <li class="flex items-center gap-2.5 text-sm text-gray-600"><span class="text-primary font-bold">✓</span> Evaluaciones básicas</li>
          <li class="flex items-center gap-2.5 text-sm text-gray-600"><span class="text-primary font-bold">✓</span> Portal de padres (solo asistencia)</li>
        </ul>
        <a href="https://wa.me/593992703156?text=Hola%20Cancha360%2C%20estoy%20interesado%20en%20solicitar%20acceso%20a%20la%20plataforma." target="_blank" class="btn-outline-dark w-full justify-center block text-center py-3 rounded-xl border border-gray-200 text-sm font-semibold text-gray-700 hover:border-primary hover:text-on-primary transition-all" style="text-decoration:none;">Empezar gratis</a>
      </div>

      <!-- PRO -->
      <div class="card-dark relative" style="border: 2px solid rgba(188,245,33,0.4);">
        <div class="flex justify-end mb-3">
          <span class="gradient-bg text-on-primary text-xs font-bold uppercase tracking-wide rounded-full px-4 py-1.5">MÁS POPULAR</span>
        </div>
        <div class="inline-block bg-surface-highest text-on-surface-variant text-xs font-bold uppercase tracking-wide rounded-full px-3 py-1 mb-5">Para crecer</div>
        <div class="mb-6">
          <span class="text-4xl font-extrabold text-white monthly-price" style="font-family: 'Lexend';">$29</span>
          <span class="text-4xl font-extrabold text-white annual-price hidden" style="font-family: 'Lexend';">$19</span>
          <span class="text-on-surface-variant text-sm ml-1">/mes</span>
          <p class="text-xs text-on-surface-variant mt-1 annual-note hidden">Facturado anualmente ($228/año)</p>
          <p class="text-xs text-on-surface-variant mt-1 monthly-note">Facturado mensualmente</p>
        </div>
        <ul class="space-y-3 mb-8">
          <li class="flex items-center gap-2.5 text-sm text-on-surface-variant"><span class="text-primary font-bold">✓</span> Equipos ilimitados</li>
          <li class="flex items-center gap-2.5 text-sm text-on-surface-variant"><span class="text-primary font-bold">✓</span> Jugadores ilimitados</li>
          <li class="flex items-center gap-2.5 text-sm text-on-surface-variant"><span class="text-primary font-bold">✓</span> Entrenadores ilimitados</li>
          <li class="flex items-center gap-2.5 text-sm text-on-surface-variant"><span class="text-primary font-bold">✓</span> Métricas personalizables</li>
          <li class="flex items-center gap-2.5 text-sm text-on-surface-variant"><span class="text-primary font-bold">✓</span> Portal de padres completo</li>
          <li class="flex items-center gap-2.5 text-sm text-on-surface-variant"><span class="text-primary font-bold">✓</span> Evaluaciones con gráficas</li>
          <li class="flex items-center gap-2.5 text-sm text-on-surface-variant"><span class="text-primary font-bold">✓</span> Notificaciones automáticas</li>
        </ul>
        <a href="https://wa.me/593992703156?text=Hola%20Cancha360%2C%20estoy%20interesado%20en%20solicitar%20acceso%20a%20la%20plataforma." target="_blank" class="btn-primary w-full justify-center block text-center" style="text-decoration:none;">Solicitar plan Pro</a>
      </div>

      <!-- ENTERPRISE -->
      <div class="card-light">
        <div class="inline-block bg-gray-100 text-gray-600 text-xs font-bold uppercase tracking-wide rounded-full px-3 py-1 mb-5">Para academias grandes</div>
        <div class="mb-6">
          <span class="text-4xl font-extrabold text-gray-900 monthly-price" style="font-family: 'Lexend';">$79</span>
          <span class="text-4xl font-extrabold text-gray-900 annual-price hidden" style="font-family: 'Lexend';">$59</span>
          <span class="text-gray-500 text-sm ml-1">/mes</span>
          <p class="text-xs text-gray-400 mt-1 annual-note hidden">Facturado anualmente</p>
          <p class="text-xs text-gray-400 mt-1 monthly-note">Facturado mensualmente</p>
        </div>
        <ul class="space-y-3 mb-8">
          <li class="flex items-center gap-2.5 text-sm text-gray-600"><span class="text-primary font-bold">✓</span> Todo lo del plan Pro</li>
          <li class="flex items-center gap-2.5 text-sm text-gray-600"><span class="text-primary font-bold">✓</span> Múltiples academias</li>
          <li class="flex items-center gap-2.5 text-sm text-gray-600"><span class="text-primary font-bold">✓</span> Soporte prioritario</li>
          <li class="flex items-center gap-2.5 text-sm text-gray-600"><span class="text-primary font-bold">✓</span> Onboarding personalizado</li>
          <li class="flex items-center gap-2.5 text-sm text-gray-600"><span class="text-primary font-bold">✓</span> Acceso a API</li>
        </ul>
        <a href="https://wa.me/593992703156?text=Hola%20Cancha360%2C%20estoy%20interesado%20en%20solicitar%20acceso%20a%20la%20plataforma." target="_blank" class="btn-outline-dark w-full justify-center block text-center py-3 rounded-xl border border-gray-200 text-sm font-semibold text-gray-700 hover:border-primary transition-all" style="text-decoration:none;">Contactar</a>
      </div>

    </div>

    <p class="text-center text-sm text-gray-400 mt-8">Todos los precios en USD. Pagos via transferencia bancaria.</p>
    <script>
      const toggle = document.getElementById('billing-toggle') as HTMLInputElement | null;
      toggle?.addEventListener('change', () => {
        const annual = toggle.checked;
        document.querySelectorAll('.monthly-price').forEach(el => el.classList.toggle('hidden', annual));
        document.querySelectorAll('.annual-price').forEach(el => el.classList.toggle('hidden', !annual));
        document.querySelectorAll('.annual-note').forEach(el => el.classList.toggle('hidden', !annual));
        document.querySelectorAll('.monthly-note').forEach(el => el.classList.toggle('hidden', annual));
      });
      // Initialize to annual state
      document.querySelectorAll('.monthly-price').forEach(el => el.classList.add('hidden'));
      document.querySelectorAll('.annual-price').forEach(el => el.classList.remove('hidden'));
      document.querySelectorAll('.annual-note').forEach(el => el.classList.remove('hidden'));
      document.querySelectorAll('.monthly-note').forEach(el => el.classList.add('hidden'));
    </script>
  </div>
</section>

