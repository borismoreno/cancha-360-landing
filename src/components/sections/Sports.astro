---
import SectionLabel from '../ui/SectionLabel.astro'

const sports = [
  { emoji: '⚽', name: 'Fútbol' },
  { emoji: '🏀', name: 'Básquet' },
  { emoji: '🎾', name: 'Tenis' },
  { emoji: '🏊', name: 'Natación' },
  { emoji: '🏃', name: 'Atletismo' },
  { emoji: '🏐', name: 'Voleibol' },
]
---

<section class="bg-gray-50 py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-6 md:px-12 text-center">
    <SectionLabel text="MULTIDEPORTE" dark={true} />
    <!-- <h2 class="mt-5 text-3xl md:text-4xl font-bold text-gray-900" style="font-family: 'Lexend', sans-serif;">No solo para fútbol</h2> -->
    <p class="mt-4 text-base text-gray-500 max-w-xl mx-auto">Cancha360 se adapta a cualquier academia deportiva. Si tienes jugadores, tenemos la herramienta.</p>

    <div class="grid grid-cols-3 md:grid-cols-6 gap-4 mt-10 max-w-3xl mx-auto">
      <!-- Each sport card -->
      <div class="card-light text-center py-5">
        <div class="text-3xl mb-2">⚽</div>
        <p class="text-xs font-semibold text-gray-600">Fútbol</p>
      </div>
      <div class="card-light text-center py-5">
        <div class="text-3xl mb-2">🏀</div>
        <p class="text-xs font-semibold text-gray-600">Básquet</p>
      </div>
      <div class="card-light text-center py-5">
        <div class="text-3xl mb-2">🎾</div>
        <p class="text-xs font-semibold text-gray-600">Tenis</p>
      </div>
      <div class="card-light text-center py-5">
        <div class="text-3xl mb-2">🏊</div>
        <p class="text-xs font-semibold text-gray-600">Natación</p>
      </div>
      <div class="card-light text-center py-5">
        <div class="text-3xl mb-2">🏃</div>
        <p class="text-xs font-semibold text-gray-600">Atletismo</p>
      </div>
      <div class="card-light text-center py-5">
        <div class="text-3xl mb-2">🏐</div>
        <p class="text-xs font-semibold text-gray-600">Voleibol</p>
      </div>
    </div>
  </div>
</section>