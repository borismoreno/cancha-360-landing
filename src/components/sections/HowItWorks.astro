---
import SectionLabel from '../ui/SectionLabel.astro'

const steps = [
  {
    n: 1,
    title: 'Solicita acceso y configura tu academia',
    description: 'Contacta por WhatsApp, te activamos la cuenta en minutos. Agrega el nombre, logo y datos de tu academia.',
  },
  {
    n: 2,
    title: 'Crea tus equipos e invita a tu staff',
    description: 'Registra tus equipos, asigna coaches e invita a los padres por email. Todo desde tu celular.',
  },
  {
    n: 3,
    title: 'Gestiona desde cualquier dispositivo',
    description: 'Registra asistencia, evalúa jugadores y los padres reciben notificaciones automáticas del progreso de sus hijos.',
  },
]
---

<section class="bg-white py-20 md:py-28" id="como-funciona">
  <div class="max-w-6xl mx-auto px-6 md:px-12">
    
    <div class="text-center max-w-2xl mx-auto mb-16">
      <SectionLabel text="ASÍ DE SIMPLE" dark={true} />
      <h2 class="mt-5 text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 leading-tight" style="font-family: 'Lexend', sans-serif;">
        Empieza a gestionar tu academia en minutos
      </h2>
    </div>

    <!-- Steps: on desktop, 3 columns with connecting line. On mobile, vertical stack -->
    <div class="relative">
      
      <!-- Connecting line (desktop only) -->
      <div class="hidden md:block absolute top-6 left-0 right-0 h-0.5 mx-32" style="background: linear-gradient(90deg, #bcf521, #00f4fe);"></div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 relative">
        
        <!-- Step 1 -->
        <div class="text-center">
          <div class="w-12 h-12 rounded-full gradient-bg flex items-center justify-center mx-auto mb-6 relative z-10 shadow-lg">
            <span style="font-family: 'Lexend'; font-weight: 800; font-size: 1.1rem; color: #425900;">1</span>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-3" style="font-family: 'Lexend', sans-serif;">Solicita acceso y configura tu academia</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Contacta por WhatsApp, te activamos la cuenta en minutos. Agrega el nombre, logo y datos de tu academia.</p>
        </div>

        <!-- Step 2 -->
        <div class="text-center">
          <div class="w-12 h-12 rounded-full gradient-bg flex items-center justify-center mx-auto mb-6 relative z-10 shadow-lg">
            <span style="font-family: 'Lexend'; font-weight: 800; font-size: 1.1rem; color: #425900;">2</span>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-3" style="font-family: 'Lexend', sans-serif;">Crea tus equipos e invita a tu staff</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Registra tus equipos, asigna coaches e invita a los padres por email. Todo desde tu celular.</p>
        </div>

        <!-- Step 3 -->
        <div class="text-center">
          <div class="w-12 h-12 rounded-full gradient-bg flex items-center justify-center mx-auto mb-6 relative z-10 shadow-lg">
            <span style="font-family: 'Lexend'; font-weight: 800; font-size: 1.1rem; color: #425900;">3</span>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-3" style="font-family: 'Lexend', sans-serif;">Gestiona desde cualquier dispositivo</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Registra asistencia, evalúa jugadores y los padres reciben notificaciones automáticas del progreso de sus hijos.</p>
        </div>

      </div>
    </div>

    <div class="text-center mt-12">
      <a href="https://wa.me/593992703156" target="_blank" class="btn-primary" style="background: linear-gradient(135deg, #bcf521, #00f4fe); color: #425900;">
        Empezar ahora
      </a>
    </div>
  </div>
</section>