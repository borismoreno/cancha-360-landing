---
import SectionLabel from '../ui/SectionLabel.astro'

const features = [
  {
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
    title: 'Gestión de jugadores',
    description: 'Registra y organiza todos tus jugadores con su historial completo, posición, equipo y datos de contacto.',
  },
  {
    icon: `<path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="m9 14 2 2 4-4"/>`,
    title: 'Control de asistencia',
    description: 'Registra la asistencia de cada entrenamiento desde tu celular en segundos. Historial completo y porcentajes automáticos.',
  },
  {
    icon: `<line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="14"/>`,
    title: 'Evaluaciones con métricas',
    description: 'Define las métricas que importan para tu academia y evalúa a tus jugadores con datos reales y gráficas de evolución.',
  },
  {
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
    title: 'Portal para padres',
    description: 'Los padres acceden a un portal dedicado para ver la asistencia y evaluaciones de su hijo en tiempo real. Sin preguntas por WhatsApp.',
  },
  {
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
    title: 'Gestión de equipos',
    description: 'Organiza tus equipos por categoría, asigna coaches, configura horarios y canchas desde un solo lugar.',
  },
  {
    icon: `<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2z"/>`,
    title: 'Para cualquier deporte',
    description: 'Diseñado para adaptarse a cualquier deporte. Fútbol, básquet, natación, tenis, atletismo y más.',
  },
]
---

<section class="bg-surface-dark py-24" id="caracteristicas">
  <div class="max-w-6xl mx-auto px-6 text-center">
    <SectionLabel text="LA SOLUCIÓN" />

    <h2 class="font-display text-3xl md:text-4xl font-bold text-white mt-5">
      Todo lo que necesitas para <span class="gradient-text">gestionar tu academia</span>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
      {features.map((f) => (
        <div class="bg-surface-high rounded-2xl p-6 gradient-border text-left">
          <div class="gradient-bg rounded-xl p-2.5 inline-block mb-4">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#425900"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={f.icon}
            />
          </div>
          <h3 class="font-display font-semibold text-on-surface text-lg mb-2">{f.title}</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
