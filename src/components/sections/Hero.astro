---
import SectionLabel from '../ui/SectionLabel.astro'
---

<section class="bg-surface-dark min-h-screen flex flex-col justify-center relative overflow-hidden pt-16">
  
  <!-- Background glows -->
  <div class="absolute top-0 right-0 w-96 h-96 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(188,245,33,0.12) 0%, transparent 70%); transform: translate(30%, -30%);"></div>
  <div class="absolute bottom-0 left-0 w-80 h-80 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(0,244,254,0.08) 0%, transparent 70%); transform: translate(-30%, 30%);"></div>

  <div class="max-w-6xl mx-auto px-6 md:px-12 py-20 md:py-28">
    <div class="max-w-3xl mx-auto text-center">
      
      <SectionLabel text="PLATAFORMA PARA ACADEMIAS DEPORTIVAS" />
      
      <h1 class="mt-6 text-4xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight" style="font-family: 'Lexend', sans-serif;">
        Gestiona tu academia deportiva con la precisión de un equipo <span class="gradient-text">profesional</span>
      </h1>
      
      <p class="mt-6 text-lg md:text-xl text-on-surface-variant leading-relaxed max-w-2xl mx-auto">
        Cancha360 centraliza la gestión de jugadores, equipos y entrenamientos — y permite a los padres seguir el progreso de sus hijos en tiempo real.
      </p>
      
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="https://wa.me/593992703156?text=Hola%20Cancha360%2C%20estoy%20interesado%20en%20solicitar%20acceso%20a%20la%20plataforma." target="_blank" class="btn-primary text-base px-7 py-3.5">
          <!-- WhatsApp icon SVG inline 20px -->
          Solicitar acceso gratis
        </a>
        <a href="#como-funciona" class="btn-outline text-base px-7 py-3.5">
          Ver cómo funciona
        </a>
      </div>

      <div class="mt-6 flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
        <span class="text-sm text-on-surface-variant flex items-center gap-1.5">
          <span class="text-primary">✓</span> Gratis para empezar
        </span>
        <span class="text-sm text-on-surface-variant flex items-center gap-1.5">
          <span class="text-primary">✓</span> Sin tarjeta de crédito
        </span>
        <span class="text-sm text-on-surface-variant flex items-center gap-1.5">
          <span class="text-primary">✓</span> Para cualquier deporte
        </span>
      </div>
    </div>

    <div class="mt-16 flex justify-center relative">
      <div class="relative flex items-end justify-center" style="height: 520px; width: 100%; max-width: 600px; margin: 0 auto;">

        <!-- Left phone — Equipos (behind, rotated left) -->
        <div class="absolute" style="left: 0; bottom: 0; transform: rotate(-8deg) translateX(20px); z-index: 1; opacity: 0.85;">
          <div class="relative rounded-4xl border-4 border-surface-high overflow-hidden shadow-2xl" style="width: 180px; box-shadow: 0 24px 48px rgba(0,0,0,0.6);">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-14 h-4 bg-surface-high rounded-b-xl z-10"></div>
            <img
              src="/screenshots/equipos.png"
              alt="Gestión de equipos en Cancha360"
              class="w-full h-auto block"
              loading="lazy"
            />
          </div>
        </div>

        <!-- Center phone — Dashboard (front, no rotation) -->
        <div class="relative" style="z-index: 3;">
          <!-- Lime glow under center phone -->
          <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-48 h-12 rounded-full blur-2xl" style="background: rgba(188,245,33,0.25);"></div>
          <div class="relative rounded-[2.5rem] border-4 border-surface-high overflow-hidden" style="width: 220px; box-shadow: 0 40px 80px rgba(0,0,0,0.7);">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-20 h-5 bg-surface-high rounded-b-2xl z-10"></div>
            <img
              src="/screenshots/dashboard.png"
              alt="Dashboard de Cancha360 — panel de control de academia deportiva"
              class="w-full h-auto block"
              loading="eager"
            />
          </div>
        </div>

        <!-- Right phone — Asistencia (behind, rotated right) -->
        <div class="absolute" style="right: 0; bottom: 0; transform: rotate(8deg) translateX(-20px); z-index: 1; opacity: 0.85;">
          <div class="relative rounded-4xl border-4 border-surface-high overflow-hidden shadow-2xl" style="width: 180px; box-shadow: 0 24px 48px rgba(0,0,0,0.6);">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-14 h-4 bg-surface-high rounded-b-xl z-10"></div>
            <img
              src="/screenshots/asistencia.png"
              alt="Control de asistencia en Cancha360"
              class="w-full h-auto block"
              loading="lazy"
            />
          </div>
        </div>

      </div>
    </div>
  </div>
</section>