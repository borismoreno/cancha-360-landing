---
import SectionLabel from '../ui/SectionLabel.astro'
---

<section class="bg-surface-dark py-20 md:py-28 relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-150 h-100 rounded-full blur-3xl" style="background: radial-gradient(ellipse, rgba(188,245,33,0.08) 0%, transparent 70%);"></div>
  </div>
  <div class="max-w-2xl mx-auto px-6 md:px-12 text-center relative">
    <SectionLabel text="EMPIEZA HOY" />
    <h2 class="mt-5 text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight" style="font-family: 'Lexend', sans-serif;">
      Sé parte de las primeras academias en Ecuador que gestionan con datos
    </h2>
    <p class="mt-5 text-base md:text-lg text-on-surface-variant">
      Acceso gratuito para empezar. Sin tarjeta de crédito. Configuración en minutos.
    </p>
    <div class="mt-8">
      <a href="https://wa.me/593992703156?text=Hola%20Cancha360%2C%20estoy%20interesado%20en%20solicitar%20acceso%20a%20la%20plataforma." target="_blank" class="btn-primary text-lg px-8 py-4">
        Solicitar acceso por WhatsApp
      </a>
    </div>
    <p class="mt-4 text-sm text-on-surface-variant">
      O escríbenos a <a href="mailto:marketing@cancha360.com" class="text-primary hover:underline">marketing@cancha360.com</a>
    </p>
  </div>
</section>