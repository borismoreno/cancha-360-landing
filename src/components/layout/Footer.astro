---
---

<footer class="bg-surface-dark text-on-surface-variant">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="hex-grad-footer" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#bcf521"/>
                <stop offset="100%" stop-color="#00f4fe"/>
              </linearGradient>
            </defs>
            <path d="M16 2L28.7 9.5V24.5L16 32L3.3 24.5V9.5L16 2Z" fill="url(#hex-grad-footer)"/>
            <path d="M16 8L22.9 12V20L16 24L9.1 20V12L16 8Z" fill="white" opacity="0.3"/>
          </svg>
          <span class="font-display font-bold text-lg text-white">Cancha360</span>
        </a>
        <p class="text-sm leading-relaxed mb-5">
          La plataforma para academias deportivas en Latinoamérica
        </p>
        <div class="flex gap-4">
          <a
            href="https://instagram.com/cancha360app"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="hover:text-primary transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
            </svg>
          </a>
          <a
            href="https://facebook.com/Cancha360"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="hover:text-primary transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Producto -->
      <div>
        <h4 class="font-display font-semibold text-white text-sm uppercase tracking-wider mb-4">Producto</h4>
        <ul class="flex flex-col gap-3 text-sm">
          <li><a href="/#como-funciona" class="hover:text-primary transition-colors">Características</a></li>
          <li><a href="/precios" class="hover:text-primary transition-colors">Precios</a></li>
          <li><a href="/blog" class="hover:text-primary transition-colors">Blog</a></li>
          <li>
            <a
              href="https://academias.cancha360.com"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-primary transition-colors"
            >
              Iniciar sesión
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="font-display font-semibold text-white text-sm uppercase tracking-wider mb-4">Legal</h4>
        <ul class="flex flex-col gap-3 text-sm">
          <li><a href="/terminos" class="hover:text-primary transition-colors">Términos y condiciones</a></li>
          <li><a href="/privacidad" class="hover:text-primary transition-colors">Política de privacidad</a></li>
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h4 class="font-display font-semibold text-white text-sm uppercase tracking-wider mb-4">Contacto</h4>
        <div class="flex flex-col gap-3">
          <a
            href="https://wa.me/593992703156"
            target="_blank"
            rel="noopener noreferrer"
            class="gradient-bg text-on-primary font-semibold rounded-xl px-4 py-2.5 text-sm text-center inline-block"
          >
            WhatsApp
          </a>
          <a
            href="mailto:marketing@cancha360.com"
            class="text-sm hover:text-primary transition-colors"
          >
            marketing@cancha360.com
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-surface-high mt-12 pt-6 text-sm text-center">
      © 2025 Cancha360. Todos los derechos reservados.
    </div>
  </div>
</footer>
