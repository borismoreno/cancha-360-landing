---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="Página no encontrada — Cancha360" description="La página que buscas no existe.">
  <section class="bg-surface-dark min-h-screen flex items-center justify-center">
    <div class="text-center px-6 max-w-lg mx-auto">
      <p class="text-8xl font-extrabold gradient-text" style="font-family: 'Lexend';">404</p>
      <h1 class="mt-4 text-3xl font-bold text-white" style="font-family: 'Lexend';">Página no encontrada</h1>
      <p class="mt-4 text-on-surface-variant">La página que buscas no existe o fue movida.</p>
      <a href="/" class="btn-primary mt-8 inline-flex">Volver al inicio</a>
    </div>
  </section>
</BaseLayout>